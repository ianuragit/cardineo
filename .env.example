# --- Database (Railway PostgreSQL plugin auto-injects DATABASE_URL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/cardineo?schema=public"

# --- Auth ---
# Generate with: npm run hash-password -- "yourClinicPassword"
CLINIC_PASSWORD_HASH="$2a$10$replace_with_a_real_bcrypt_hash"
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace_with_a_long_random_string_at_least_32_chars"

# --- App ---
# The public URL of the deployed app. Used to build the intake QR code.
# Locally: http://localhost:3000  — On Railway: paste the generated domain.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CLINIC_NAME="Cardineo Heart Clinic"
DOCTOR_NAME="Dr. A. Sharma"
